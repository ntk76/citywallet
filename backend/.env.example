PORT=8787

# --- Tavily (Pflicht für Live-Daten statt Fallback) ---
# 1) Kopiere diese Datei:  cp .env.example .env   (Windows: copy .env.example .env)
# 2) Trage in .env einen ECHTEN Key von https://tavily.com/ ein (kein Platzhalter).
# 3) Prüfen: GET http://localhost:8787/health  → "tavilyApiKeyConfigured": true
#    Danach: GET http://localhost:8787/events → "eventsMeta"."source" soll "tavily" sein (nicht "fallback").
TAVILY_API_KEY=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

CACHE_TTL_MINUTES=20
TAVILY_TIMEOUT_MS=6000

# Optional: Stadt/Region für Tavily (siehe application.properties)
# EVENTS_SEARCH_CITY=Munich
# EVENTS_SEARCH_REGION=Balanstrasse
# EVENTS_TIMEZONE=Europe/Berlin
